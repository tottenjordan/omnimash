# ==============================================================================
# OmniMash Environment Configuration Template
# Copy this file to .env and configure your local cloud resource names and keys:
#   cp .env.example .env
# ==============================================================================

# 1. Google Cloud Platform Settings
GOOGLE_CLOUD_PROJECT=hybrid-vertex
GOOGLE_CLOUD_REGION=us-central1

# 2. Cloud Storage Media Bucket
# If left blank, defaults automatically to: omnimash-media-${GOOGLE_CLOUD_PROJECT}
OMNIMASH_GCS_BUCKET=omnimash-media-934903580331

# 3. Model Armor & Vertex AI Authentication
# Leave GEMINI_API_KEY blank if authenticating via Application Default Credentials (ADC)
GEMINI_API_KEY=
MODEL_ARMOR_TEMPLATE_ID=omnimash-safety-filter

# 4. Runtime & Feature Flags
MOCK_MODE=true
PORT=8080
LOG_LEVEL=INFO
